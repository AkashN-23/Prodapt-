# ─── Required API keys ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. It is already listed in .gitignore.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Data paths (defaults work if you run build scripts from repo root) ───────
VECTOR_STORE_PATH=./data/chroma_store
SQLITE_DB_PATH=./data/financials.db

# ─── Agent tuning ─────────────────────────────────────────────────────────────
# Model used for the agent loop. Use claude-haiku-4-5-20251001 during development
# to keep costs low; switch to claude-opus-4-6 for final evaluation.
AGENT_MODEL=claude-haiku-4-5-20251001
